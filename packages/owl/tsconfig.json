{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "types": ["vue/jsx"],
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["./**/*.ts", "./**/*.tsx", "./**/*.vue"]
}
